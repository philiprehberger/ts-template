{
  "name": "@philiprehberger/template",
  "version": "0.1.2",
  "description": "Lightweight string template engine with safe interpolation, conditionals, and loops",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["template", "interpolation", "mustache", "handlebars", "string", "render"],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/philiprehberger/ts-template.git" },
  "homepage": "https://github.com/philiprehberger/ts-template#readme",
  "bugs": { "url": "https://github.com/philiprehberger/ts-template/issues" },
  "devDependencies": { "tsup": "^8.0.0", "typescript": "^5.0.0" },
  "engines": { "node": ">=18.0.0" },
  "sideEffects": false
}
